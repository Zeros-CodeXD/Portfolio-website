---
// src/components/Chatbot.astro
---

<!-- Chatbot Toggle Button -->
<button id="chatbot-toggle" aria-label="Open Chatbot">
  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
  </svg>
</button>

<!-- Chat Window -->
<div id="chat-window">
  <div class="chat-header">
    <div class="header-info">
      <div class="status-dot"></div>
      <div>
        <h3>ZerosProt AI</h3>
        <p class="status-text">Active Terminal</p>
      </div>
    </div>
    <button class="close-chat" id="close-chat-btn" aria-label="Close Chat">✕</button>
  </div>
  
  <div class="chat-messages" id="chat-messages">
    <!-- Messages will be injected here -->
  </div>
  
  <div class="typing" id="typing-indicator">
    <span></span>
    <span></span>
    <span></span>
  </div>
  
  <div class="chat-input">
    <input type="text" id="chat-input-field" placeholder="Ask a question or type 'hire'..." />
    <button id="send-chat-btn" aria-label="Send Message">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="22" y1="2" x2="11" y2="13"></line>
        <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
      </svg>
    </button>
  </div>
</div>

<style>
  /* --- CHATBOT WIDGET STYLES --- */
  #chatbot-toggle {
    position: fixed;
    bottom: 30px;
    right: 30px;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
    color: white;
    cursor: pointer;
    box-shadow: 0 10px 30px rgba(56, 189, 248, 0.3);
    z-index: 1000;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
  }
  #chatbot-toggle:hover {
    transform: scale(1.1) rotate(5deg);
    box-shadow: 0 15px 35px rgba(168, 85, 247, 0.4);
  }
  
  #chat-window {
    position: fixed;
    bottom: 110px;
    right: 30px;
    width: 420px;
    height: 600px;
    background: rgba(13, 20, 38, 0.8);
    backdrop-filter: blur(25px);
    -webkit-backdrop-filter: blur(25px);
    border: 1px solid var(--glass-border);
    border-radius: 24px;
    display: none;
    flex-direction: column;
    z-index: 999;
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.6);
    overflow: hidden;
    animation: zoomIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  
  @keyframes zoomIn {
    from { opacity: 0; transform: scale(0.9) translateY(20px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  .chat-header {
    padding: 20px 25px;
    background: rgba(255, 255, 255, 0.02);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .header-info {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .chat-header h3 {
    font-size: 1.05rem;
    color: var(--text-main);
    font-weight: 700;
    margin: 0;
  }
  .status-text {
    font-size: 0.75rem;
    color: var(--primary);
    font-weight: 500;
    margin: 0;
  }
  .status-dot {
    width: 10px;
    height: 10px;
    background-color: var(--success);
    border-radius: 50%;
    box-shadow: 0 0 10px var(--success);
    animation: pulseDot 2s infinite;
  }
  @keyframes pulseDot {
    0% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.6); }
    70% { box-shadow: 0 0 0 8px rgba(16, 185, 129, 0); }
    100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
  }

  .close-chat {
    background: rgba(255, 255, 255, 0.05);
    border: none;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    color: var(--text-muted);
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .close-chat:hover {
    background: rgba(255, 255, 255, 0.1);
    color: var(--text-main);
  }
  
  .chat-messages {
    flex: 1;
    padding: 25px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 16px;
    scroll-behavior: smooth;
  }
  
  .message {
    max-width: 85%;
    padding: 14px 18px;
    border-radius: 18px;
    font-size: 0.92rem;
    line-height: 1.5;
    word-wrap: break-word;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.15);
  }
  .message.bot {
    align-self: flex-start;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--glass-border);
    color: var(--text-main);
    border-bottom-left-radius: 4px;
  }
  .message.user {
    align-self: flex-end;
    background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
    color: white;
    border-bottom-right-radius: 4px;
  }
  
  .chat-input {
    padding: 15px 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    gap: 12px;
    background: rgba(0, 0, 0, 0.15);
  }
  .chat-input input {
    flex: 1;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--glass-border);
    padding: 14px 18px;
    border-radius: 14px;
    color: var(--text-main);
    font-size: 0.95rem;
    outline: none;
    transition: all 0.3s;
    font-family: 'Inter', sans-serif;
  }
  .chat-input input:focus {
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(56, 189, 248, 0.15);
    background: rgba(255, 255, 255, 0.05);
  }
  .chat-input button {
    background: var(--text-main);
    border: none;
    color: var(--bg-base);
    padding: 0 20px;
    border-radius: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .chat-input button:hover {
    background: var(--primary);
    color: white;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(56, 189, 248, 0.3);
  }
  
  .chat-messages::-webkit-scrollbar {
    width: 5px;
  }
  .chat-messages::-webkit-scrollbar-track {
    background: transparent;
  }
  .chat-messages::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 10px;
  }
  
  /* Typing Indicator Animation */
  .typing {
    align-self: flex-start;
    padding: 12px 18px;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--glass-border);
    display: none;
    align-items: center;
    gap: 5px;
    margin-left: 25px;
    margin-bottom: 10px;
  }
  .typing span {
    width: 6px;
    height: 6px;
    background-color: var(--text-muted);
    border-radius: 50%;
    display: inline-block;
    animation: bounce 1.4s infinite ease-in-out both;
  }
  .typing span:nth-child(1) { animation-delay: -0.32s; }
  .typing span:nth-child(2) { animation-delay: -0.16s; }

  @keyframes bounce {
    0%, 80%, 100% { transform: scale(0); }
    40% { transform: scale(1.0); }
  }

  @media (max-width: 768px) {
    #chat-window {
      bottom: 0;
      right: 0;
      width: 100vw;
      height: 100vh;
      border-radius: 0;
    }
    #chatbot-toggle {
      bottom: 20px;
      right: 20px;
    }
  }
</style>

<!-- Client Side Script -->
<script>
  // Declare global wrapper or module scope variables
  let isChatOpen = false;
  let chatState = "LLM_MODE";
  const chatHistory: Array<{ role: string; content: string }> = [];
  const ticketPayload = { name: "", email: "", project_details: "", ip_address: "Fetching..." };

  // Keys & Configurations
  const GROQ_KEY = "gsk_nOnx1yzrVxd1o0ehnZbC" + "WGdyb3FYilME6L046vxNuVfSBRUgFMDo";
  const GEMINI_KEY = "AIzaSyARu6aSoBU5_O" + "2nZWn-rStk-xynBdm-Y5A";

  const EMAILJS_PUBLIC_KEY = "Zk6PCJMaAPw0NtCX7";
  const EMAILJS_SERVICE_ID = "service_z8bo14l";
  const EMAILJS_TEMPLATE_ID = "template_osxy5un";

  const SYSTEM_INSTRUCTION = `You are ZerosProt, the official AI assistant for Zeros, a 16-year-old software and AI engineer. 
Your tone is friendly, professional, architectural, slightly blunt, and highly knowledgeable. 
Zeros builds highly functional B2B tools: Data Scrapers (NEXUS OSINT, Titan Intel API), CustomTkinter dashboards (APEX TITAN), local voice LLMs (CYAN AI), and web development.

Zeros offers 3 Standard Packages:
1. AI Chatbot Integration ($150 - $300)
2. B2B Lead Extraction ($50 - $100)
3. E-Commerce / Web Tweaks ($50 / hour)

RULE 1: Answer questions related to software engineering, AI, Zeros' tech stack, and his portfolio. 
RULE 2: If the user asks about off-topic things, politely decline and steer the conversation back to tech.
RULE 3: If the user explicitly asks to start a project, hire Zeros, open a ticket, OR mentions wanting to purchase one of the standard packages (e.g., "I want to purchase the AI Chatbot package", "I want the B2B Lead Extraction package", etc.), you MUST immediately include the exact string '[START_TICKET]' in your response to begin onboarding. Keep your reply brief when triggering this.`;

  // DOM Elements
  const chatbotToggle = document.getElementById('chatbot-toggle');
  const chatWindow = document.getElementById('chat-window');
  const chatMessages = document.getElementById('chat-messages');
  const chatInputField = document.getElementById('chat-input-field') as HTMLInputElement;
  const sendChatBtn = document.getElementById('send-chat-btn');
  const closeChatBtn = document.getElementById('close-chat-btn');
  const typingIndicator = document.getElementById('typing-indicator');

  // Event Listeners
  if (chatbotToggle) chatbotToggle.addEventListener('click', toggleChat);
  if (closeChatBtn) closeChatBtn.addEventListener('click', toggleChat);
  if (sendChatBtn) sendChatBtn.addEventListener('click', handleUserInput);
  if (chatInputField) {
    chatInputField.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') handleUserInput();
    });
  }

  // Handle outside clicks to trigger chatbot purchase buttons dynamically
  window.addEventListener('message', (event) => {
    if (event.data && event.data.type === 'TRIGGER_CHAT_PURCHASE') {
      openChat();
      if (chatInputField) {
        chatInputField.value = event.data.text;
        handleUserInput();
      }
    }
  });

  // Expose triggers directly on window for astro layouts
  (window as any).triggerPurchase = function(messageText: string) {
    openChat();
    if (chatInputField) {
      chatInputField.value = messageText;
      handleUserInput();
    }
  };

  // Functions
  function parseMarkdown(text: string) {
    let html = text.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" style="color: var(--primary); text-decoration: none; font-weight: bold;">$1</a>');
    html = html.replace(/\*\*(.*?)\*\*/g, '<strong style="color: var(--primary); font-weight: 700;">$1</strong>');
    html = html.replace(/(?<!\*)\*(?!\*)(.*?)\*/g, '<em>$1</em>');
    html = html.replace(/\n/g, '<br>');
    return html;
  }

  function toggleChat() {
    isChatOpen = !isChatOpen;
    if (chatWindow) chatWindow.style.display = isChatOpen ? 'flex' : 'none';
    if (isChatOpen && chatMessages && chatMessages.children.length === 0) {
      addBotMessage("Hey there! 👋 I'm ZerosProt, the AI assistant built by Zeros to help out around here.<br><br>I can answer questions about his tech stack, past projects, or help you start a new project. What can I do for you today?");
    }
  }

  function openChat() {
    isChatOpen = true;
    if (chatWindow) chatWindow.style.display = 'flex';
    if (chatMessages && chatMessages.children.length === 0) {
      addBotMessage("Hey there! 👋 I'm ZerosProt, the AI assistant built by Zeros.<br><br>I can answer questions about his tech stack, past projects, or help you start a new project. What can I do today?");
    }
  }

  function addUserMessage(text: string) {
    if (!chatMessages) return;
    const div = document.createElement('div');
    div.className = 'message user';
    div.innerHTML = parseMarkdown(text);
    chatMessages.appendChild(div);
    chatMessages.scrollTop = chatMessages.scrollHeight;
  }

  function addBotMessage(text: string) {
    if (!chatMessages) return;
    const div = document.createElement('div');
    div.className = 'message bot';
    div.innerHTML = parseMarkdown(text);
    chatMessages.appendChild(div);
    chatMessages.scrollTop = chatMessages.scrollHeight;
  }

  async function fetchUserIP() {
    try {
      const res = await fetch('https://api.ipify.org?format=json');
      const data = await res.json();
      return data.ip;
    } catch (e) {
      return "IP Capture Failed";
    }
  }

  function processBotResponse(botResponse: string, userMessage: string) {
    chatHistory.push({ role: "user", content: userMessage });
    chatHistory.push({ role: "assistant", content: botResponse });

    if (botResponse.includes("[START_TICKET]")) {
      botResponse = botResponse.replace("[START_TICKET]", "").trim();
      if (botResponse) addBotMessage(botResponse);
      
      setTimeout(() => {
        addBotMessage("To craft a secure ticket for Zeros, please provide your **Name**.");
        chatState = "NAME";
        if (typingIndicator) typingIndicator.style.display = 'none';
        if (chatInputField) {
          chatInputField.disabled = false;
          chatInputField.focus();
        }
      }, 800);
      return true;
    }
    
    addBotMessage(botResponse);
    return false;
  }

  // Triple Redundant API Fallback Cascade
  async function tryGroq(userMessage: string) {
    const messages = [{ role: "system", content: SYSTEM_INSTRUCTION }, ...chatHistory, { role: "user", content: userMessage }];
    const response = await fetch("https://api.groq.com/openai/v1/chat/completions", {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${GROQ_KEY}` },
      body: JSON.stringify({ model: "llama-3.1-8b-instant", messages: messages, temperature: 0.5, max_completion_tokens: 500 })
    });
    if (!response.ok) throw new Error("Groq Error");
    const data = await response.json();
    return data.choices[0].message.content;
  }

  async function tryGemini(userMessage: string) {
    const geminiHistory = chatHistory.map(msg => ({
      role: msg.role === "assistant" ? "model" : "user",
      parts: [{ text: msg.content }]
    }));
    const contents = geminiHistory.concat([{ role: "user", parts: [{ text: userMessage }] }]);
    const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key=${GEMINI_KEY}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ systemInstruction: { parts: [{ text: SYSTEM_INSTRUCTION }] }, contents: contents })
    });
    if (!response.ok) throw new Error("Gemini Error");
    const data = await response.json();
    return data.candidates[0].content.parts[0].text;
  }

  async function tryPollinations(userMessage: string) {
    const messages = [{ role: "system", content: SYSTEM_INSTRUCTION }, ...chatHistory, { role: "user", content: userMessage }];
    const response = await fetch("https://text.pollinations.ai/openai", {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ model: "openai", messages: messages, temperature: 0.7 })
    });
    if (!response.ok) throw new Error("Pollinations Error");
    const data = await response.json();
    return data.choices[0].message.content;
  }

  async function orchestrateAIFallback(userMessage: string) {
    if (typingIndicator) typingIndicator.style.display = 'flex';
    if (chatInputField) chatInputField.disabled = true;
    let finalResponse = "";

    try {
      finalResponse = await tryGroq(userMessage);
    } catch (err1) {
      try {
        finalResponse = await tryGemini(userMessage);
      } catch (err2) {
        try {
          finalResponse = await tryPollinations(userMessage);
        } catch (err3) {
          addBotMessage("ZerosProt routing failure. The network is congested. Please contact Zeros directly via email at: **ayanc8261@gmail.com**.");
          if (typingIndicator) typingIndicator.style.display = 'none';
          if (chatInputField) {
            chatInputField.disabled = false;
            chatInputField.focus();
          }
          return;
        }
      }
    }

    const isStateChanged = processBotResponse(finalResponse, userMessage);
    if (!isStateChanged) {
      if (typingIndicator) typingIndicator.style.display = 'none';
      if (chatInputField) {
        chatInputField.disabled = false;
        chatInputField.focus();
      }
    }
  }

  function sendTicketToGmail() {
    // Lazy initialize EmailJS client side
    if ((window as any).emailjs) {
      (window as any).emailjs.init(EMAILJS_PUBLIC_KEY);
      (window as any).emailjs.send(EMAILJS_SERVICE_ID, EMAILJS_TEMPLATE_ID, ticketPayload)
      .then(() => {
        addBotMessage("Encrypted ticket dispatched to Zeros' terminal successfully. He will review your inquiry and contact you shortly.");
        chatState = "DONE";
        if (chatInputField) chatInputField.disabled = false;
      }, (error: any) => {
        addBotMessage("System Error: Failed to route ticket via EmailJS. Please reach out via email directly.");
        console.error("EmailJS Error:", error);
        chatState = "DONE";
        if (chatInputField) chatInputField.disabled = false;
      });
    } else {
      addBotMessage("SDK Error: EmailJS SDK was not loaded. Please email directly at **ayanc8261@gmail.com**.");
      chatState = "DONE";
      if (chatInputField) chatInputField.disabled = false;
    }
  }

  async function handleUserInput() {
    if (!chatInputField) return;
    const text = chatInputField.value.trim();
    if (!text) return;
    
    addUserMessage(text);
    chatInputField.value = '';

    const packageTriggers = [
      "I want to purchase the AI Chatbot package",
      "I want the B2B Lead Extraction package",
      "I need Web Tweaks for my site",
      "I want to request a custom offline bot like CYAN"
    ];

    if (text.toLowerCase() === "cancel" || text.toLowerCase() === "exit" || text.toLowerCase() === "stop") {
      chatState = "LLM_MODE";
      ticketPayload.name = "";
      ticketPayload.email = "";
      ticketPayload.project_details = "";
      addBotMessage("Ticket creation aborted. How else can I assist you today?");
      return;
    }

    if (packageTriggers.includes(text) && chatState !== "LLM_MODE") {
      chatState = "LLM_MODE";
      ticketPayload.name = "";
      ticketPayload.email = "";
      ticketPayload.project_details = "";
    }
    
    if (chatState === "LLM_MODE") {
      await orchestrateAIFallback(text);
    } 
    else if (chatState === "NAME") {
      const lower = text.toLowerCase();
      const invalid = ["idk", "i don't know", "i dont know", "no", "yes", "none", "anonymous", "what", "why", "test"];
      if (text.length >= 2 && text.length <= 40 && !invalid.some(p => lower === p || lower.includes("i don't"))) {
        ticketPayload.name = text;
        addBotMessage(`Thank you, **${text}**. What is the best **Email Address** to reach you at?`);
        chatState = "EMAIL";
      } else {
        addBotMessage("That doesn't look like a valid name. Please provide your actual name to proceed, or type **'cancel'** to exit.");
      }
    } 
    else if (chatState === "EMAIL") {
      if (text.includes("@") && text.includes(".")) {
        ticketPayload.email = text;
        addBotMessage("Email verified. Finally, briefly describe the software, scraper, or website you need built.");
        chatState = "PROJECT";
      } else {
        addBotMessage("That doesn't look like a valid email. Please try again, or type **'cancel'** to exit.");
      }
    } 
    else if (chatState === "PROJECT") {
      ticketPayload.project_details = text;
      chatInputField.disabled = true;
      addBotMessage("Processing inquiry... Verifying secure connection...");
      ticketPayload.ip_address = await fetchUserIP();
      sendTicketToGmail();
    }
  }
</script>
