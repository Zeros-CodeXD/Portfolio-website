---
import Layout from '../layouts/Layout.astro';
import Chatbot from '../components/Chatbot.astro';
---

<Layout
  title="ZEROS | Contact"
  description="Start a project, ask a question, or request a custom build. Use the chatbot or email directly."
  activePage="/contact"
>
  <div class="page-hero">
    <p class="eyebrow">Get in Touch</p>
    <h1 class="page-title">Let's Build Something</h1>
    <p class="page-sub">The fastest way to reach me is through the chatbot below — it logs a ticket automatically. Or email me directly.</p>
  </div>

  <div class="contact-container">

    <!-- Options grid -->
    <div class="contact-grid reveal">

      <!-- Chatbot card -->
      <div class="contact-card primary-card">
        <div class="card-icon">💬</div>
        <h2>Chat with the Bot</h2>
        <p>Click the chat button in the bottom-right corner. Describe your project and it will log a ticket via EmailJS. I reply within 24 hours.</p>
        <div class="option-tags">
          <span class="opt-tag">Fastest response</span>
          <span class="opt-tag">Auto-logged ticket</span>
          <span class="opt-tag">Available 24/7</span>
        </div>
        <button class="btn-primary" id="open-chat-btn">Open Chatbot →</button>
      </div>

      <!-- Email card -->
      <div class="contact-card">
        <div class="card-icon">📧</div>
        <h2>Email Directly</h2>
        <p>If you prefer email, reach me at the address below. Include a brief description of what you need and I'll reply with a quote.</p>
        <div class="option-tags">
          <span class="opt-tag">ayanc8261@gmail.com</span>
        </div>
        <a href="mailto:ayanc8261@gmail.com" class="btn-outline">Send an Email →</a>
      </div>

    </div>

    <!-- Quick prompts -->
    <div class="quick-section reveal" style="--delay:120ms">
      <h2 class="quick-title">Quick Start — Pick a prompt</h2>
      <p class="quick-sub">Click any card to open the chatbot with a pre-filled message.</p>
      <div class="quick-grid">
        <button class="quick-card" id="q1">
          <span>🤖</span>
          <strong>AI Chatbot Integration</strong>
          <p>I want a custom AI chatbot on my website</p>
        </button>
        <button class="quick-card" id="q2">
          <span>🕵️</span>
          <strong>OSINT Lead Extraction</strong>
          <p>I need targeted business contact data</p>
        </button>
        <button class="quick-card" id="q3">
          <span>🛠️</span>
          <strong>Web Fixes / Dev</strong>
          <p>I need help with my existing website</p>
        </button>
        <button class="quick-card" id="q4">
          <span>🎙️</span>
          <strong>Custom Offline AI</strong>
          <p>I want something like CYAN for my use case</p>
        </button>
        <button class="quick-card" id="q5">
          <span>📈</span>
          <strong>Custom Trading Tool</strong>
          <p>I need a custom analytics or trading dashboard</p>
        </button>
        <button class="quick-card" id="q6">
          <span>💡</span>
          <strong>Something else</strong>
          <p>I have an idea I want to discuss</p>
        </button>
      </div>
    </div>

    <!-- FAQ -->
    <div class="faq-section reveal" style="--delay:200ms">
      <h2 class="faq-title">Common Questions</h2>
      <div class="faq-list">
        <details class="faq-item">
          <summary>How fast do you deliver?</summary>
          <p>Simple packages (lead extraction, chatbot integration) are typically 24–72 hours. Larger custom builds are scoped on a per-project basis with a agreed deadline before any payment.</p>
        </details>
        <details class="faq-item">
          <summary>Do you work with clients outside India?</summary>
          <p>Yes — 100%. I work with clients globally. Payments via PayPal, crypto, or any agreed method.</p>
        </details>
        <details class="faq-item">
          <summary>What if the delivered work has bugs?</summary>
          <p>I fix bugs in delivered work for free within 7 days of delivery. After that, fixes are billed at the hourly rate.</p>
        </details>
        <details class="faq-item">
          <summary>Can I see code before paying?</summary>
          <p>All my public projects are on GitHub — you can review the code quality there. For custom builds, 50% upfront and 50% on delivery is the standard arrangement.</p>
        </details>
      </div>
    </div>

  </div>

  <Chatbot />
</Layout>

<style>
  .page-hero { text-align: center; padding: 80px 24px 40px; position: relative; z-index: 10; }
  .eyebrow { font-size: 0.78rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--primary); margin-bottom: 12px; }
  .page-title { font-size: 3.2rem; font-weight: 800; letter-spacing: -2px; background: linear-gradient(135deg,#fff 0%,#a5b4fc 100%); -webkit-background-clip:text; -webkit-text-fill-color:transparent; margin-bottom: 14px; }
  .page-sub { font-size: 1.05rem; color: var(--text-muted); max-width: 560px; margin: 0 auto; line-height: 1.6; }

  .contact-container { max-width: 900px; margin: 0 auto; padding: 40px 24px 96px; position: relative; z-index: 10; display: flex; flex-direction: column; gap: 56px; }

  /* CONTACT CARDS */
  .contact-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; }
  .contact-card { background: rgba(13,20,38,0.55); border: 1px solid var(--glass-border); border-radius: 22px; padding: 36px 32px; display: flex; flex-direction: column; gap: 14px; transition: transform 0.3s, border-color 0.3s; }
  .contact-card:hover { transform: translateY(-4px); border-color: rgba(56,189,248,0.2); }
  .primary-card { border-color: rgba(56,189,248,0.2); box-shadow: 0 12px 40px rgba(56,189,248,0.06); }
  .card-icon { font-size: 2rem; }
  .contact-card h2 { font-size: 1.4rem; font-weight: 700; color: var(--text-main); }
  .contact-card p { color: var(--text-muted); font-size: 0.92rem; line-height: 1.65; flex-grow: 1; }
  .option-tags { display: flex; flex-wrap: wrap; gap: 8px; }
  .opt-tag { font-size: 0.72rem; font-weight: 600; padding: 4px 12px; border-radius: 20px; background: rgba(56,189,248,0.07); color: var(--primary); border: 1px solid rgba(56,189,248,0.2); }
  .btn-primary { padding: 13px 24px; border-radius: 12px; font-size: 0.92rem; font-weight: 600; text-decoration: none; background: linear-gradient(135deg,var(--primary),var(--secondary)); color: white; transition: all 0.3s; box-shadow: 0 6px 20px rgba(56,189,248,0.25); cursor: pointer; border: none; font-family: 'Inter', sans-serif; display: inline-block; }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(168,85,247,0.35); }
  .btn-outline { padding: 13px 24px; border-radius: 12px; font-size: 0.92rem; font-weight: 600; text-decoration: none; background: rgba(255,255,255,0.03); color: var(--text-main); border: 1px solid var(--glass-border); transition: all 0.3s; display: inline-block; }
  .btn-outline:hover { border-color: var(--primary); background: rgba(56,189,248,0.05); transform: translateY(-2px); }

  /* QUICK PROMPTS */
  .quick-title { font-size: 1.6rem; font-weight: 800; letter-spacing: -0.5px; color: var(--text-main); margin-bottom: 8px; }
  .quick-sub { font-size: 0.9rem; color: var(--text-muted); margin-bottom: 24px; }
  .quick-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 14px; }
  .quick-card { display: flex; flex-direction: column; align-items: flex-start; gap: 6px; text-align: left; background: rgba(255,255,255,0.02); border: 1px solid var(--glass-border); border-radius: 16px; padding: 20px 22px; cursor: pointer; transition: all 0.3s; font-family: 'Inter', sans-serif; }
  .quick-card:hover { background: rgba(56,189,248,0.06); border-color: rgba(56,189,248,0.25); transform: translateY(-3px); }
  .quick-card span { font-size: 1.4rem; }
  .quick-card strong { font-size: 0.9rem; font-weight: 700; color: var(--text-main); }
  .quick-card p { font-size: 0.8rem; color: var(--text-muted); margin: 0; line-height: 1.4; }

  /* FAQ */
  .faq-title { font-size: 1.6rem; font-weight: 800; letter-spacing: -0.5px; color: var(--text-main); margin-bottom: 24px; }
  .faq-list { display: flex; flex-direction: column; gap: 12px; }
  .faq-item { background: rgba(255,255,255,0.02); border: 1px solid var(--glass-border); border-radius: 14px; overflow: hidden; transition: border-color 0.3s; }
  .faq-item[open] { border-color: rgba(56,189,248,0.2); }
  .faq-item summary { padding: 20px 24px; font-size: 0.95rem; font-weight: 600; color: var(--text-main); cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .faq-item summary::after { content: '+'; font-size: 1.2rem; color: var(--primary); transition: transform 0.3s; }
  .faq-item[open] summary::after { content: '−'; }
  .faq-item p { padding: 0 24px 20px; font-size: 0.9rem; color: var(--text-muted); line-height: 1.65; }
</style>

<script>
  const trigger = (msg: string) => (window as any).triggerPurchase?.(msg);

  document.getElementById('open-chat-btn')?.addEventListener('click', () => trigger('I want to start a project with you'));
  document.getElementById('q1')?.addEventListener('click', () => trigger('I want to purchase the AI Chatbot package'));
  document.getElementById('q2')?.addEventListener('click', () => trigger('I want the OSINT Lead Extraction package'));
  document.getElementById('q3')?.addEventListener('click', () => trigger('I need Web Fixes for my site'));
  document.getElementById('q4')?.addEventListener('click', () => trigger('I want a custom offline AI assistant like CYAN'));
  document.getElementById('q5')?.addEventListener('click', () => trigger('I want a custom trading or analytics dashboard'));
  document.getElementById('q6')?.addEventListener('click', () => trigger('I have an idea I want to discuss with you'));
</script>
